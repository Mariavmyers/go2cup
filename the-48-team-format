<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Complete guide to the 2026 FIFA World Cup 48-team format — 12 groups, 104 matches, Round of 32, and what it means for fans traveling across the U.S., Mexico, and Canada.">
<title>2026 FIFA World Cup: The 48-Team Format Explained | GO2CUP</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&display=swap');

  :root {
    --navy: #0A1628;
    --navy-mid: #0F1F3D;
    --navy-card: #111D35;
    --navy-border: #1A2D50;
    --teal: #00D4AA;
    --teal-dim: rgba(0,212,170,0.12);
    --teal-glow: rgba(0,212,170,0.25);
    --gold: #F4C95D;
    --gold-dim: rgba(244,201,93,0.12);
    --white: #F0F4FF;
    --muted: #7A8FAD;
    --danger: #FF5E5E;
    --danger-dim: rgba(255,94,94,0.1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background-color: var(--navy);
    color: var(--white);
    font-family: 'Barlow', sans-serif;
    font-weight: 400;
    line-height: 1.7;
    font-size: 16px;
    overflow-x: hidden;
  }

  /* ── BACKGROUND TEXTURE ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 10% 0%, rgba(0,212,170,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 90% 100%, rgba(244,201,93,0.05) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── LAYOUT ── */
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
  .container--narrow { max-width: 780px; margin: 0 auto; padding: 0 24px; }

  /* ── NAVIGATION ── */
  nav {
    background: rgba(10,22,40,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--navy-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .logo {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.6rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: var(--white);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .logo span { color: var(--teal); }

  .nav-links {
    display: flex;
    gap: 4px;
    list-style: none;
  }

  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    padding: 6px 12px;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }

  .nav-links a:hover { color: var(--white); background: var(--navy-border); }

  .nav-toggle {
    display: none;
    background: none;
    border: 1px solid var(--navy-border);
    color: var(--white);
    padding: 8px 12px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 1.1rem;
  }

  /* ── HERO ── */
  .hero {
    padding: 80px 0 72px;
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: '48';
    position: absolute;
    right: -60px;
    top: 50%;
    transform: translateY(-50%);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 22rem;
    color: rgba(0,212,170,0.04);
    pointer-events: none;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--teal-dim);
    border: 1px solid rgba(0,212,170,0.3);
    color: var(--teal);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 24px;
  }

  .badge::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.2rem, 6vw, 4.2rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-bottom: 20px;
    max-width: 700px;
  }

  h1 .accent { color: var(--teal); }

  .hero-sub {
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    color: rgba(240,244,255,0.72);
    max-width: 580px;
    margin-bottom: 36px;
    font-weight: 300;
    line-height: 1.65;
  }

  .cta-row { display: flex; gap: 12px; flex-wrap: wrap; }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 24px;
    border-radius: 8px;
    font-family: 'Barlow', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--teal);
    color: var(--navy);
  }
  .btn-primary:hover { background: #00EDBC; transform: translateY(-1px); box-shadow: 0 8px 24px var(--teal-glow); }

  .btn-secondary {
    background: transparent;
    color: var(--white);
    border: 1.5px solid var(--navy-border);
  }
  .btn-secondary:hover { border-color: var(--teal); color: var(--teal); transform: translateY(-1px); }

  .btn-gold {
    background: var(--gold);
    color: var(--navy);
  }
  .btn-gold:hover { background: #FFD96B; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(244,201,93,0.3); }

  /* ── SECTION STRUCTURE ── */
  section { padding: 64px 0; }
  section + section { border-top: 1px solid var(--navy-border); }

  .section-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 12px;
  }

  h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(1.7rem, 4vw, 2.6rem);
    line-height: 1.1;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    margin-bottom: 10px;
    letter-spacing: 0.01em;
  }

  p { margin-bottom: 14px; color: rgba(240,244,255,0.85); }
  p:last-child { margin-bottom: 0; }

  ul {
    list-style: none;
    margin-bottom: 14px;
  }

  ul li {
    color: rgba(240,244,255,0.85);
    padding: 5px 0 5px 22px;
    position: relative;
  }

  ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    width: 8px;
    height: 2px;
    background: var(--teal);
    border-radius: 2px;
  }

  strong { color: var(--white); font-weight: 600; }

  /* ── STAT GRID ── */
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 16px;
    margin-top: 36px;
  }

  .stat-card {
    background: var(--navy-card);
    border: 1px solid var(--navy-border);
    border-radius: 12px;
    padding: 24px 20px;
    text-align: center;
    transition: border-color 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--teal);
    transform: scaleX(0);
    transition: transform 0.3s;
    transform-origin: left;
  }

  .stat-card:hover { border-color: var(--teal); transform: translateY(-3px); }
  .stat-card:hover::before { transform: scaleX(1); }

  .stat-number {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 2.8rem;
    color: var(--teal);
    line-height: 1;
    margin-bottom: 6px;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* ── CARDS ── */
  .card {
    background: var(--navy-card);
    border: 1px solid var(--navy-border);
    border-radius: 12px;
    padding: 28px;
    transition: border-color 0.2s;
  }

  .card:hover { border-color: var(--navy-border); }

  .card-teal { border-left: 3px solid var(--teal); }
  .card-gold { border-left: 3px solid var(--gold); }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-top: 32px;
  }

  /* ── GROUP EXAMPLE TABLE ── */
  .group-example {
    background: var(--navy-card);
    border: 1px solid var(--navy-border);
    border-radius: 12px;
    overflow: hidden;
    margin-top: 28px;
  }

  .group-header {
    background: var(--teal-dim);
    border-bottom: 1px solid rgba(0,212,170,0.2);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .group-tag {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.08em;
    color: var(--teal);
  }

  .group-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 24px;
    border-bottom: 1px solid var(--navy-border);
    transition: background 0.15s;
  }

  .group-row:last-child { border-bottom: none; }
  .group-row:hover { background: rgba(255,255,255,0.03); }

  .team-flag {
    width: 28px;
    height: 20px;
    background: var(--navy-border);
    border-radius: 3px;
    display: inline-block;
    margin-right: 12px;
    vertical-align: middle;
    position: relative;
    overflow: hidden;
  }

  .team-name { font-weight: 500; font-size: 0.95rem; }
  .team-note { font-size: 0.75rem; color: var(--muted); font-weight: 500; }

  /* ── FORMULA BOX ── */
  .formula-box {
    background: var(--navy-card);
    border: 1px solid var(--navy-border);
    border-radius: 12px;
    padding: 32px;
    margin-top: 28px;
    text-align: center;
  }

  .formula {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .formula-item {
    background: var(--teal-dim);
    border: 1px solid rgba(0,212,170,0.25);
    border-radius: 8px;
    padding: 12px 18px;
    text-align: center;
  }

  .formula-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 2rem;
    color: var(--teal);
    line-height: 1;
  }

  .formula-desc {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 4px;
  }

  .formula-op {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--muted);
  }

  .formula-result {
    border-top: 1px solid var(--navy-border);
    padding-top: 16px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1.3rem;
    color: var(--gold);
  }

  /* ── CAUTION BOX ── */
  .caution-box {
    background: var(--danger-dim);
    border: 1px solid rgba(255,94,94,0.25);
    border-left: 3px solid var(--danger);
    border-radius: 8px;
    padding: 18px 22px;
    margin-top: 20px;
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .caution-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; }
  .caution-box p { color: rgba(240,244,255,0.8); font-size: 0.9rem; margin: 0; }

  /* ── KNOCKOUT PATH ── */
  .path-diagram {
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    padding: 28px 0;
    margin-top: 8px;
  }

  .path-stage {
    flex-shrink: 0;
    text-align: center;
    position: relative;
  }

  .path-bubble {
    background: var(--navy-card);
    border: 1px solid var(--navy-border);
    border-radius: 10px;
    padding: 14px 18px;
    min-width: 110px;
    transition: all 0.2s;
  }

  .path-stage:first-child .path-bubble { border-color: var(--teal); }
  .path-stage:last-child .path-bubble { border-color: var(--gold); background: var(--gold-dim); }

  .path-stage:hover .path-bubble { border-color: var(--teal); transform: translateY(-2px); }

  .path-round {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: var(--teal);
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .path-teams {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 500;
  }

  .path-arrow {
    flex-shrink: 0;
    color: var(--navy-border);
    font-size: 1.2rem;
    padding: 0 8px;
  }

  /* ── QUAL DIAGRAM ── */
  .qual-diagram {
    background: var(--navy-card);
    border: 1px solid var(--navy-border);
    border-radius: 12px;
    padding: 32px;
    margin-top: 28px;
  }

  .qual-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .qual-source {
    background: var(--navy);
    border: 1px solid var(--navy-border);
    border-radius: 8px;
    padding: 10px 18px;
    font-size: 0.85rem;
    font-weight: 500;
    min-width: 200px;
    text-align: center;
  }

  .qual-arrow-r { color: var(--teal); font-size: 1.2rem; font-weight: 700; flex-shrink: 0; }

  .qual-result {
    background: var(--teal-dim);
    border: 1px solid rgba(0,212,170,0.3);
    border-radius: 8px;
    padding: 10px 18px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--teal);
    min-width: 140px;
    text-align: center;
  }

  .qual-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 8px 0 16px;
  }

  .qual-line { flex: 1; height: 1px; background: var(--navy-border); }
  .qual-plus { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1.2rem; color: var(--muted); }

  .qual-final {
    background: var(--gold-dim);
    border: 1px solid rgba(244,201,93,0.3);
    border-radius: 8px;
    padding: 14px 24px;
    text-align: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--gold);
    letter-spacing: 0.04em;
    margin-top: 8px;
  }

  /* ── FAQ ── */
  .faq-list { margin-top: 28px; }

  .faq-item {
    background: var(--navy-card);
    border: 1px solid var(--navy-border);
    border-radius: 10px;
    margin-bottom: 10px;
    overflow: hidden;
  }

  .faq-q {
    width: 100%;
    background: none;
    border: none;
    color: var(--white);
    font-family: 'Barlow', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    text-align: left;
    padding: 18px 22px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    transition: background 0.15s;
  }

  .faq-q:hover { background: rgba(255,255,255,0.03); }

  .faq-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--teal-dim);
    border: 1px solid rgba(0,212,170,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    color: var(--teal);
    transition: transform 0.2s;
    font-style: normal;
  }

  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .faq-a {
    display: none;
    padding: 0 22px 18px;
    color: rgba(240,244,255,0.78);
    font-size: 0.92rem;
    line-height: 1.65;
    border-top: 1px solid var(--navy-border);
    padding-top: 16px;
  }

  .faq-item.open .faq-a { display: block; }

  /* ── TRAVEL INTEL ── */
  .travel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
    margin-top: 28px;
  }

  .travel-card {
    background: var(--navy-card);
    border: 1px solid var(--navy-border);
    border-radius: 12px;
    padding: 22px;
    transition: all 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .travel-card:hover { border-color: var(--teal); transform: translateY(-3px); }

  .travel-icon {
    font-size: 1.6rem;
    margin-bottom: 12px;
    display: block;
  }

  .travel-card h3 { font-size: 1rem; margin-bottom: 8px; }
  .travel-card p { font-size: 0.85rem; color: var(--muted); margin: 0; }

  .travel-card .link-arrow {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--teal);
    font-size: 0.8rem;
    font-weight: 600;
    margin-top: 12px;
    letter-spacing: 0.03em;
  }

  /* ── CTA SECTION ── */
  .cta-section {
    background: var(--navy-card);
    border: 1px solid var(--navy-border);
    border-radius: 16px;
    padding: 48px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--teal), transparent);
  }

  .cta-section h2 { margin-bottom: 14px; }
  .cta-section p { max-width: 540px; margin: 0 auto 32px; font-size: 1rem; }

  .cta-btn-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  /* ── OFFICIAL NOTE ── */
  .official-note {
    background: var(--navy-mid);
    border: 1px solid var(--navy-border);
    border-radius: 10px;
    padding: 20px 24px;
    margin-top: 40px;
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .official-note strong { color: rgba(240,244,255,0.7); }

  /* ── FOOTER ── */
  footer {
    background: var(--navy-mid);
    border-top: 1px solid var(--navy-border);
    padding: 48px 0 32px;
    margin-top: 80px;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    flex-wrap: wrap;
    margin-bottom: 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--navy-border);
  }

  .footer-logo {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    color: var(--white);
  }

  .footer-logo span { color: var(--teal); }

  .footer-tagline {
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 4px;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 24px;
    list-style: none;
  }

  .footer-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--teal); }

  .footer-disclaimer {
    font-size: 0.78rem;
    color: rgba(122,143,173,0.7);
    line-height: 1.65;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .nav-links { display: none; flex-direction: column; position: absolute; top: 64px; left: 0; right: 0; background: rgba(10,22,40,0.98); border-bottom: 1px solid var(--navy-border); padding: 16px; gap: 4px; }
    .nav-links.open { display: flex; }
    .nav-toggle { display: block; }
    .nav-inner { position: relative; }
    .hero { padding: 52px 0 56px; }
    .hero::after { font-size: 12rem; right: -20px; opacity: 0.6; }
    .stat-grid { grid-template-columns: repeat(3, 1fr); }
    .path-diagram { gap: 0; }
